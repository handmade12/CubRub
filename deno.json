{
  "nodeModulesDir": true,
  "lock": true,
  "tasks": {
    "dev": "deno task --cwd=apps/web dev",
    "build": "deno task --cwd=apps/web build",
    "check": "deno fmt --check . && deno lint . && deno check",
    "test": "deno test --allow-read"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "exclude": [
    "**/_fresh/*",
    "**/dist/*",
    "**/node_modules/*"
  ]
}
